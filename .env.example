# ──────────────────────────────────────────────────────────────────────────
# KalendHair 4.0 — Variables d'environnement (exemple)
# Copier ce fichier en `.env` et adapter si besoin.
# ⚠️ Ne JAMAIS pointer vers une base de production. DB locale uniquement.
# ──────────────────────────────────────────────────────────────────────────

# ─── Base de données ──────────────────────────────────────────────────────
# PostgreSQL local (cf. docker-compose.yml)
DATABASE_URL="postgresql://kalendhair:kalendhair@localhost:5432/kalendhair_dev?schema=public"

# ─── Auth JWT ─────────────────────────────────────────────────────────────
# Clé de signature tenant HS256 (minimum 32 caractères)
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
JWT_SECRET="remplacer-par-une-cle-secrete-dau-moins-32-caracteres"

# Clé de signature Super Admin (optionnel — utilise JWT_SECRET si absent)
# Si fourni, il sera préfixé : admin:${ADMIN_JWT_SECRET}
# Recommandé en production pour une séparation forte des secrets.
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# ADMIN_JWT_SECRET=""

# ─── Email transactionnel — Resend ────────────────────────────────────────
# https://resend.com — Laisser vide pour désactiver (notifications → SKIPPED)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@kalendhair.fr"
RESEND_FROM_NAME="KalendHair"

# ─── Formulaire de contact — Candidatures pilotes ─────────────────────────
# Adresse de réception des candidatures soumises via /contact
# Si absent, fallback sur "contact@kalendhair.fr"
CONTACT_TO_EMAIL="contact@kalendhair.fr"

# ─── CRON — Rappels automatiques email (Sprint 15) ────────────────────────
# Vercel injecte ce secret en header Authorization lors des invocations CRON.
# En local : curl -H "Authorization: Bearer <valeur>" /api/cron/reminders
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
CRON_SECRET=""

# ─── Observabilité — Sentry ───────────────────────────────────────────────
# Sans DSN, Sentry est désactivé silencieusement — l'appli reste fonctionnelle.
# SENTRY_DSN côté serveur (non exposé au navigateur)
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN côté client (exposé au navigateur — projet public uniquement)
# NEXT_PUBLIC_SENTRY_DSN=""
