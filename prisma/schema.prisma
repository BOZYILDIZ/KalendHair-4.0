// Prisma schema — KalendHair 4.0
// Sprint 2 : schéma complet (21 modèles, 13 enums).
// Arbitrages validés : cuid(), Int centimes, Int minutes, Client cross-tenant,
// guest* sur Appointment, 1 service/RDV MVP, organizationId dénormalisé,
// passwordHash nullable, Stripe placeholders nullable, soft-delete isActive,
// startAt/endAt UTC + Salon.timezone, @@map snake_case.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------------

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  OTHER

  @@map("payment_method")
}

enum PaymentStatus {
  COMPLETED
  CANCELLED

  @@map("payment_status")
}

enum ProRole {
  OWNER
  MANAGER
  EMPLOYEE

  @@map("pro_role")
}

enum SubscriptionPlan {
  FREE
  STARTER
  PRO

  @@map("subscription_plan")
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID

  @@map("subscription_status")
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY

  @@map("day_of_week")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  NO_SHOW
  COMPLETED

  @@map("appointment_status")
}

enum AppointmentModificationType {
  CREATED
  RESCHEDULED
  CANCELLED
  STATUS_CHANGED
  NOTE_UPDATED

  @@map("appointment_modification_type")
}

enum NotificationChannel {
  EMAIL

  @@map("notification_channel")
}

enum NotificationType {
  APPOINTMENT_CONFIRMATION
  APPOINTMENT_REMINDER
  APPOINTMENT_CANCELLED

  @@map("notification_type")
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED

  @@map("notification_status")
}

enum NotificationPreferenceScope {
  PRO_USER
  CLIENT
  SALON

  @@map("notification_preference_scope")
}

enum IntegrationProvider {
  GOOGLE_CALENDAR
  OUTLOOK
  WHATSAPP
  BREVO
  INSTAGRAM

  @@map("integration_provider")
}

enum IntegrationAuthType {
  OAUTH2
  API_KEY
  WEBHOOK

  @@map("integration_auth_type")
}

enum IntegrationStatus {
  ACTIVE
  INACTIVE
  ERROR
  PENDING_AUTH

  @@map("integration_status")
}

enum StockMovementType {
  ENTRY      // réapprovisionnement manuel
  SALE       // vente via caisse POS (lié à un Payment)
  USAGE      // utilisation lors d'une prestation
  ADJUSTMENT // correction d'inventaire (différence constatée)

  @@map("stock_movement_type")
}

// ---------------------------------------------------------------------------
// TENANT & COMPTES
// ---------------------------------------------------------------------------

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  proUsers     ProUser[]
  salons       Salon[]
  employees    Employee[]
  subscription Subscription?
  integrations IntegrationConnection[]
  auditLogs    AuditLog[]
  featureFlags FeatureFlag[]

  @@map("organizations")
}

model ProUser {
  id             String   @id @default(cuid())
  organizationId String
  email          String   @unique
  firstName      String
  lastName       String
  role           ProRole  @default(EMPLOYEE)
  passwordHash   String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employees       Employee[]
  auditLogs       AuditLog[]     @relation("AuditLogActor")
  createdPayments Payment[]
  stockMovements  StockMovement[]

  @@index([organizationId])
  @@map("pro_users")
}

model Subscription {
  id                     String             @id @default(cuid())
  organizationId         String             @unique
  plan                   SubscriptionPlan   @default(FREE)
  status                 SubscriptionStatus @default(TRIALING)
  // Stripe placeholders — nullable, inactifs au MVP
  stripeCustomerId       String?            @unique
  stripeSubscriptionId   String?            @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ---------------------------------------------------------------------------
// SALON & RÉFÉRENTIEL
// ---------------------------------------------------------------------------

model Salon {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  slug           String   @unique
  description    String?
  phone          String?
  email          String?
  address        String?
  city           String?
  postalCode     String?
  timezone       String   @default("Europe/Paris")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employees      Employee[]
  services       Service[]
  appointments   Appointment[]
  salonSchedules SalonSchedule[]
  closedDays     ClosedDay[]
  salonClients   SalonClient[]
  notifications    Notification[]
  integrations     IntegrationConnection[]
  payments          Payment[]
  receiptCounters   SalonReceiptCounter[]
  productCategories ProductCategory[]
  products          Product[]
  productStocks     ProductStock[]
  stockMovements    StockMovement[]

  @@unique([organizationId])
  @@index([organizationId])
  @@map("salons")
}

model FrenchCity {
  id         String @id @default(cuid())
  insee      String @unique
  name       String
  postalCode String
  department String
  region     String

  @@index([postalCode])
  @@map("french_cities")
}

// ---------------------------------------------------------------------------
// ÉQUIPE & PRESTATIONS
// ---------------------------------------------------------------------------

model Employee {
  id             String   @id @default(cuid())
  organizationId String
  salonId        String
  proUserId      String?
  firstName      String
  lastName       String
  email          String?
  phone          String?
  color          String? // couleur agenda
  photoUrl       String? // préparation Sprint 7+ (upload)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salon             Salon              @relation(fields: [salonId], references: [id], onDelete: Cascade)
  proUser           ProUser?           @relation(fields: [proUserId], references: [id], onDelete: SetNull)
  employeeServices  EmployeeService[]
  employeeSchedules EmployeeSchedule[]
  appointments      Appointment[]

  @@index([organizationId])
  @@index([salonId])
  @@map("employees")
}

model Service {
  id              String   @id @default(cuid())
  organizationId  String
  salonId         String
  name            String
  description     String?
  durationMinutes Int
  priceCents      Int
  currency        String   @default("EUR")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  salon            Salon             @relation(fields: [salonId], references: [id], onDelete: Cascade)
  employeeServices EmployeeService[]
  appointments     Appointment[]
  paymentLines     PaymentLine[]

  @@index([salonId])
  @@map("services")
}

model EmployeeService {
  id         String   @id @default(cuid())
  employeeId String
  serviceId  String
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([employeeId, serviceId])
  @@map("employee_services")
}

// ---------------------------------------------------------------------------
// HORAIRES
// ---------------------------------------------------------------------------

model SalonSchedule {
  id          String    @id @default(cuid())
  salonId     String
  dayOfWeek   DayOfWeek
  startMinute Int // minutes depuis minuit (ex: 540 = 09:00)
  endMinute   Int // minutes depuis minuit (ex: 1080 = 18:00)
  isOpen      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  salon Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([salonId])
  @@map("salon_schedules")
}

model EmployeeSchedule {
  id          String    @id @default(cuid())
  employeeId  String
  dayOfWeek   DayOfWeek
  startMinute Int
  endMinute   Int
  isWorking   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("employee_schedules")
}

model ClosedDay {
  id        String   @id @default(cuid())
  salonId   String
  date      DateTime @db.Date
  reason    String?
  createdAt DateTime @default(now())

  salon Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@unique([salonId, date])
  @@map("closed_days")
}

// ---------------------------------------------------------------------------
// RENDEZ-VOUS
// ---------------------------------------------------------------------------

model Appointment {
  id                 String            @id @default(cuid())
  organizationId     String
  salonId            String
  employeeId         String
  serviceId          String
  clientId           String? // null si RDV invité
  // Champs invité (guest) — null si clientId renseigné
  guestFirstName     String?
  guestLastName      String?
  guestEmail         String?
  guestPhone         String?
  priceCentsSnapshot Int? // prix capturé à la création du RDV (immuable)
  startAt            DateTime // UTC
  endAt              DateTime // UTC
  status             AppointmentStatus @default(PENDING)
  notes              String?
  isActive           Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  salon         Salon                     @relation(fields: [salonId], references: [id], onDelete: Restrict)
  employee      Employee                  @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  service       Service                   @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  client        Client?                   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  modifications AppointmentModification[]
  review        Review?
  notifications Notification[]
  payments      Payment[]

  @@index([salonId, startAt])
  @@index([employeeId, startAt])
  @@index([employeeId, startAt, endAt])
  @@index([clientId])
  @@index([organizationId, startAt])
  @@map("appointments")
}

model AppointmentModification {
  id               String                      @id @default(cuid())
  appointmentId    String
  modifiedById     String? // ProUser ou null (client/guest)
  modificationType AppointmentModificationType
  previousStartAt  DateTime?
  previousEndAt    DateTime?
  previousStatus   AppointmentStatus?
  note             String?
  createdAt        DateTime                    @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@map("appointment_modifications")
}

// ---------------------------------------------------------------------------
// CLIENTS & AVIS
// ---------------------------------------------------------------------------

model Client {
  id        String   @id @default(cuid())
  email     String
  firstName String
  lastName  String
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Cross-tenant : le client existe globalement,
  // les liens salon passent par SalonClient.
  salonClients  SalonClient[]
  appointments  Appointment[]
  notifications Notification[]
  payments      Payment[]

  @@index([email])
  @@index([phone])
  @@map("clients")
}

model SalonClient {
  id        String   @id @default(cuid())
  salonId   String
  clientId  String
  notes     String? // notes internes du salon
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salon  Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([salonId, clientId])
  @@index([salonId, createdAt])
  @@map("salon_clients")
}

model Review {
  id            String   @id @default(cuid())
  appointmentId String   @unique // 1 avis par RDV
  clientId      String
  salonId       String
  rating        Int // 1–5
  comment       String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([salonId])
  @@map("reviews")
}

// ---------------------------------------------------------------------------
// NOTIFICATIONS
// ---------------------------------------------------------------------------

model Notification {
  id            String              @id @default(cuid())
  salonId       String
  clientId      String?
  appointmentId String?
  channel       NotificationChannel @default(EMAIL)
  type          NotificationType
  status        NotificationStatus  @default(PENDING)
  sentAt        DateTime?
  errorMessage  String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  salon       Salon        @relation(fields: [salonId], references: [id], onDelete: Cascade)
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([salonId])
  @@index([clientId])
  @@index([appointmentId])
  @@map("notifications")
}

model NotificationPreference {
  id        String                      @id @default(cuid())
  scope     NotificationPreferenceScope
  scopeId   String // proUserId, clientId ou salonId selon scope
  type      NotificationType
  channel   NotificationChannel
  isEnabled Boolean                     @default(true)
  createdAt DateTime                    @default(now())
  updatedAt DateTime                    @updatedAt

  @@unique([scope, scopeId, type, channel])
  @@map("notification_preferences")
}

// ---------------------------------------------------------------------------
// INTÉGRATIONS & TRANSVERSE
// ---------------------------------------------------------------------------

model IntegrationConnection {
  id                   String              @id @default(cuid())
  organizationId       String
  salonId              String?
  provider             IntegrationProvider
  authType             IntegrationAuthType
  status               IntegrationStatus   @default(INACTIVE)
  // Les credentials ne sont JAMAIS stockés en clair.
  // Ils sont chiffrés avant insertion et déchiffrés à la lecture.
  encryptedCredentials String?
  expiresAt            DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salon        Salon?       @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("integration_connections")
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  actorId        String? // ProUser (null si action système)
  action         String
  entityType     String
  entityId       String
  metadata       Json?
  ipAddress      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        ProUser?     @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model FeatureFlag {
  id             String   @id @default(cuid())
  organizationId String
  flag           String
  isEnabled      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, flag])
  @@index([organizationId])
  @@map("feature_flags")
}

// ---------------------------------------------------------------------------
// CAISSE (POS) — Sprint 14
// ---------------------------------------------------------------------------

model Payment {
  id                 String        @id @default(cuid())
  organizationId     String
  salonId            String
  appointmentId      String?
  clientId           String?
  guestName          String?
  method             PaymentMethod
  status             PaymentStatus @default(COMPLETED)
  amountCents        Int
  paidAt             DateTime
  receiptNumber      String?
  notes              String?
  createdByProUserId String?
  isActive           Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  salon       Salon        @relation(fields: [salonId], references: [id], onDelete: Restrict)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdBy   ProUser?     @relation(fields: [createdByProUserId], references: [id], onDelete: SetNull)
  lines       PaymentLine[]

  @@index([salonId, paidAt])
  @@index([appointmentId])
  @@index([clientId])
  @@index([organizationId, paidAt])
  @@index([createdByProUserId])
  @@map("payments")
}

model PaymentLine {
  id             String   @id @default(cuid())
  paymentId      String
  label          String
  unitPriceCents Int
  quantity       Int      @default(1)
  totalCents     Int      // toujours = unitPriceCents * quantity, calculé côté service
  serviceId      String?
  createdAt      DateTime @default(now())

  payment Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([paymentId])
  @@map("payment_lines")
}

// ---------------------------------------------------------------------------
// STOCKS & PRODUITS — Sprint 16
// ---------------------------------------------------------------------------

model ProductCategory {
  id             String   @id @default(cuid())
  salonId        String
  organizationId String
  name           String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  salon    Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([salonId, name])
  @@index([salonId])
  @@map("product_categories")
}

model Product {
  id                String   @id @default(cuid())
  salonId           String
  organizationId    String
  categoryId        String?
  name              String
  description       String?
  unit              String   @default("unité")
  priceCents        Int
  costPriceCents    Int?
  lowStockThreshold Int      @default(5)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  salon     Salon            @relation(fields: [salonId], references: [id], onDelete: Restrict)
  category  ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  stock     ProductStock?
  movements StockMovement[]

  @@index([salonId])
  @@index([organizationId])
  @@map("products")
}

model ProductStock {
  id        String   @id @default(cuid())
  salonId   String
  productId String   @unique
  quantity  Int      @default(0)
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  salon   Salon   @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([salonId])
  @@map("product_stocks")
}

model StockMovement {
  id                 String            @id @default(cuid())
  salonId            String
  organizationId     String
  productId          String
  type               StockMovementType
  quantityDelta      Int
  quantityBefore     Int
  quantityAfter      Int
  costPriceCents     Int?
  notes              String?
  referenceId        String?
  referenceType      String?
  createdByProUserId String?
  createdAt          DateTime          @default(now())

  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Restrict)
  createdBy ProUser? @relation(fields: [createdByProUserId], references: [id], onDelete: SetNull)

  @@index([salonId, createdAt])
  @@index([productId, createdAt])
  @@index([organizationId, createdAt])
  @@map("stock_movements")
}

// ---------------------------------------------------------------------------
// CAISSE POS — Compteur numérotation reçus (Sprint 15)
// ---------------------------------------------------------------------------

// Compteur de numérotation des reçus — 1 ligne par (salon, année)
// Incrémenté atomiquement dans la $transaction de création de paiement
model SalonReceiptCounter {
  id      String @id @default(cuid())
  salonId String
  year    Int
  lastSeq Int    @default(0)

  salon Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@unique([salonId, year])
  @@map("salon_receipt_counters")
}
