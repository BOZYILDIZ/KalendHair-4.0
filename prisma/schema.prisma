// Prisma schema — KalendHair 4.0
// Sprint 2 : schéma complet (21 modèles, 13 enums).
// Arbitrages validés : cuid(), Int centimes, Int minutes, Client cross-tenant,
// guest* sur Appointment, 1 service/RDV MVP, organizationId dénormalisé,
// passwordHash nullable, Stripe placeholders nullable, soft-delete isActive,
// startAt/endAt UTC + Salon.timezone, @@map snake_case.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------------

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  OTHER

  @@map("payment_method")
}

enum PaymentStatus {
  COMPLETED
  CANCELLED

  @@map("payment_status")
}

enum ProRole {
  OWNER
  MANAGER
  EMPLOYEE

  @@map("pro_role")
}

enum SubscriptionPlan {
  FREE
  STARTER
  PRO

  @@map("subscription_plan")
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID

  @@map("subscription_status")
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY

  @@map("day_of_week")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  NO_SHOW
  COMPLETED

  @@map("appointment_status")
}

enum AppointmentModificationType {
  CREATED
  RESCHEDULED
  CANCELLED
  STATUS_CHANGED
  NOTE_UPDATED

  @@map("appointment_modification_type")
}

enum NotificationChannel {
  EMAIL

  @@map("notification_channel")
}

enum NotificationType {
  APPOINTMENT_CONFIRMATION
  APPOINTMENT_REMINDER
  APPOINTMENT_CANCELLED

  @@map("notification_type")
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED

  @@map("notification_status")
}

enum NotificationPreferenceScope {
  PRO_USER
  CLIENT
  SALON

  @@map("notification_preference_scope")
}

enum IntegrationProvider {
  GOOGLE_CALENDAR
  OUTLOOK
  WHATSAPP
  BREVO
  INSTAGRAM

  @@map("integration_provider")
}

enum IntegrationAuthType {
  OAUTH2
  API_KEY
  WEBHOOK

  @@map("integration_auth_type")
}

enum IntegrationStatus {
  ACTIVE
  INACTIVE
  ERROR
  PENDING_AUTH

  @@map("integration_status")
}

enum StockMovementType {
  ENTRY      // réapprovisionnement manuel
  SALE       // vente via caisse POS (lié à un Payment)
  USAGE      // utilisation lors d'une prestation
  ADJUSTMENT       // correction d'inventaire (différence constatée)
  PURCHASE_RECEIPT // réception d'un bon de commande fournisseur

  @@map("stock_movement_type")
}

enum PurchaseOrderStatus {
  DRAFT              // brouillon éditable
  SENT               // transmis au fournisseur
  PARTIALLY_RECEIVED // au moins une réception, reste à recevoir
  RECEIVED           // toutes les lignes reçues intégralement
  CANCELLED          // annulé (uniquement depuis DRAFT ou SENT)

  @@map("purchase_order_status")
}

// Sprint 18 — Billing Core
enum SubscriptionPlanCode {
  ESSENTIAL
  PRO
  BUSINESS

  @@map("subscription_plan_code")
}

enum BillingCycle {
  MONTHLY
  YEARLY

  @@map("billing_cycle")
}

// OrgSubscriptionStatus : distinct de l'enum legacy SubscriptionStatus (Stripe placeholders Sprint 2)
enum OrgSubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED

  @@map("org_subscription_status")
}

// Sprint 19 — Super Admin SaaS
enum AdminAction {
  CHANGE_PLAN
  GRANT_FREE_PLAN
  REVOKE_FREE_PLAN
  CHANGE_BILLING_CYCLE
  CREATE_DISCOUNT
  DEACTIVATE_DISCOUNT
  SUSPEND_ORGANIZATION
  REACTIVATE_ORGANIZATION
  EXTEND_TRIAL
  ADMIN_IMPERSONATION_START
  ADMIN_IMPERSONATION_END
  ADD_NOTE
  UPDATE_NOTE
  DELETE_NOTE

  @@map("admin_action")
}

enum CommissionType {
  PERCENTAGE
  FIXED_AMOUNT
  @@map("commission_type")
}

enum CommissionEntryStatus {
  PENDING
  CONFIRMED
  CANCELLED
  ADJUSTED
  @@map("commission_entry_status")
}

enum DiscountType {
  PERCENT
  FIXED_AMOUNT

  @@map("discount_type")
}

// ---------------------------------------------------------------------------
// TENANT & COMPTES
// ---------------------------------------------------------------------------

model Organization {
  id                  String    @id @default(cuid())
  name                String
  slug                String    @unique
  isActive            Boolean   @default(true)
  suspensionReason    String?   @map("suspension_reason")
  suspendedAt         DateTime? @map("suspended_at")
  suspendedByAdminId  String?   @map("suspended_by_admin_id")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  proUsers           ProUser[]
  salons             Salon[]
  employees          Employee[]
  subscription       Subscription?
  orgSubscription    OrganizationSubscription?
  integrations       IntegrationConnection[]
  auditLogs          AuditLog[]
  featureFlags       FeatureFlag[]
  adminAuditLogs     AdminAuditLog[]
  adminNotes         OrganizationAdminNote[]
  impersonationLogs  AdminImpersonationLog[]
  commissionRules    CommissionRule[]
  commissionEntries  CommissionEntry[]

  @@map("organizations")
}

model ProUser {
  id             String   @id @default(cuid())
  organizationId String
  email          String   @unique
  firstName      String
  lastName       String
  role           ProRole  @default(EMPLOYEE)
  passwordHash   String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employees       Employee[]
  auditLogs       AuditLog[]     @relation("AuditLogActor")
  createdPayments        Payment[]
  stockMovements         StockMovement[]
  purchaseOrders         PurchaseOrder[]
  purchaseOrderReceipts  PurchaseOrderReceipt[]
  commissionRulesCreated CommissionRule[]
  commissionAdjustments  CommissionAdjustment[]

  @@index([organizationId])
  @@map("pro_users")
}

model Subscription {
  id                     String             @id @default(cuid())
  organizationId         String             @unique
  plan                   SubscriptionPlan   @default(FREE)
  status                 SubscriptionStatus @default(TRIALING)
  // Stripe placeholders — nullable, inactifs au MVP
  stripeCustomerId       String?            @unique
  stripeSubscriptionId   String?            @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ---------------------------------------------------------------------------
// SALON & RÉFÉRENTIEL
// ---------------------------------------------------------------------------

model Salon {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  slug           String   @unique
  description    String?
  phone          String?
  email          String?
  address        String?
  city           String?
  postalCode     String?
  timezone       String   @default("Europe/Paris")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employees      Employee[]
  services       Service[]
  appointments   Appointment[]
  salonSchedules SalonSchedule[]
  closedDays     ClosedDay[]
  salonClients   SalonClient[]
  notifications    Notification[]
  integrations     IntegrationConnection[]
  payments          Payment[]
  receiptCounters   SalonReceiptCounter[]
  productCategories     ProductCategory[]
  products              Product[]
  productStocks         ProductStock[]
  stockMovements        StockMovement[]
  suppliers             Supplier[]
  purchaseOrders        PurchaseOrder[]
  purchaseOrderReceipts PurchaseOrderReceipt[]
  commissionRules       CommissionRule[]
  commissionEntries     CommissionEntry[]

  @@unique([organizationId])
  @@index([organizationId])
  @@map("salons")
}

model FrenchCity {
  id         String @id @default(cuid())
  insee      String @unique
  name       String
  postalCode String
  department String
  region     String

  @@index([postalCode])
  @@map("french_cities")
}

// ---------------------------------------------------------------------------
// ÉQUIPE & PRESTATIONS
// ---------------------------------------------------------------------------

model Employee {
  id             String   @id @default(cuid())
  organizationId String
  salonId        String
  proUserId      String?
  firstName      String
  lastName       String
  email          String?
  phone          String?
  color          String? // couleur agenda
  photoUrl       String? // préparation Sprint 7+ (upload)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salon             Salon              @relation(fields: [salonId], references: [id], onDelete: Cascade)
  proUser           ProUser?           @relation(fields: [proUserId], references: [id], onDelete: SetNull)
  employeeServices  EmployeeService[]
  employeeSchedules EmployeeSchedule[]
  appointments      Appointment[]
  commissionRules   CommissionRule[]
  commissionEntries CommissionEntry[]

  @@index([organizationId])
  @@index([salonId])
  @@map("employees")
}

model Service {
  id              String   @id @default(cuid())
  organizationId  String
  salonId         String
  name            String
  description     String?
  durationMinutes Int
  priceCents      Int
  currency        String   @default("EUR")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  salon            Salon             @relation(fields: [salonId], references: [id], onDelete: Cascade)
  employeeServices EmployeeService[]
  appointments     Appointment[]
  paymentLines     PaymentLine[]
  commissionRules  CommissionRule[]

  @@index([salonId])
  @@map("services")
}

model EmployeeService {
  id         String   @id @default(cuid())
  employeeId String
  serviceId  String
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([employeeId, serviceId])
  @@map("employee_services")
}

// ---------------------------------------------------------------------------
// HORAIRES
// ---------------------------------------------------------------------------

model SalonSchedule {
  id          String    @id @default(cuid())
  salonId     String
  dayOfWeek   DayOfWeek
  startMinute Int // minutes depuis minuit (ex: 540 = 09:00)
  endMinute   Int // minutes depuis minuit (ex: 1080 = 18:00)
  isOpen      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  salon Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([salonId])
  @@map("salon_schedules")
}

model EmployeeSchedule {
  id          String    @id @default(cuid())
  employeeId  String
  dayOfWeek   DayOfWeek
  startMinute Int
  endMinute   Int
  isWorking   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("employee_schedules")
}

model ClosedDay {
  id        String   @id @default(cuid())
  salonId   String
  date      DateTime @db.Date
  reason    String?
  createdAt DateTime @default(now())

  salon Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@unique([salonId, date])
  @@map("closed_days")
}

// ---------------------------------------------------------------------------
// RENDEZ-VOUS
// ---------------------------------------------------------------------------

model Appointment {
  id                 String            @id @default(cuid())
  organizationId     String
  salonId            String
  employeeId         String
  serviceId          String
  clientId           String? // null si RDV invité
  // Champs invité (guest) — null si clientId renseigné
  guestFirstName     String?
  guestLastName      String?
  guestEmail         String?
  guestPhone         String?
  priceCentsSnapshot Int? // prix capturé à la création du RDV (immuable)
  startAt            DateTime // UTC
  endAt              DateTime // UTC
  status             AppointmentStatus @default(PENDING)
  notes              String?
  isActive           Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  salon         Salon                     @relation(fields: [salonId], references: [id], onDelete: Restrict)
  employee      Employee                  @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  service       Service                   @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  client        Client?                   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  modifications     AppointmentModification[]
  review            Review?
  notifications     Notification[]
  payments          Payment[]
  commissionEntries CommissionEntry[]

  @@index([salonId, startAt])
  @@index([employeeId, startAt])
  @@index([employeeId, startAt, endAt])
  @@index([clientId])
  @@index([organizationId, startAt])
  @@map("appointments")
}

model AppointmentModification {
  id               String                      @id @default(cuid())
  appointmentId    String
  modifiedById     String? // ProUser ou null (client/guest)
  modificationType AppointmentModificationType
  previousStartAt  DateTime?
  previousEndAt    DateTime?
  previousStatus   AppointmentStatus?
  note             String?
  createdAt        DateTime                    @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@map("appointment_modifications")
}

// ---------------------------------------------------------------------------
// CLIENTS & AVIS
// ---------------------------------------------------------------------------

model Client {
  id        String   @id @default(cuid())
  email     String
  firstName String
  lastName  String
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Cross-tenant : le client existe globalement,
  // les liens salon passent par SalonClient.
  salonClients  SalonClient[]
  appointments  Appointment[]
  notifications Notification[]
  payments      Payment[]

  @@index([email])
  @@index([phone])
  @@map("clients")
}

model SalonClient {
  id        String   @id @default(cuid())
  salonId   String
  clientId  String
  notes     String? // notes internes du salon
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salon  Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([salonId, clientId])
  @@index([salonId, createdAt])
  @@map("salon_clients")
}

model Review {
  id            String   @id @default(cuid())
  appointmentId String   @unique // 1 avis par RDV
  clientId      String
  salonId       String
  rating        Int // 1–5
  comment       String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([salonId])
  @@map("reviews")
}

// ---------------------------------------------------------------------------
// NOTIFICATIONS
// ---------------------------------------------------------------------------

model Notification {
  id            String              @id @default(cuid())
  salonId       String
  clientId      String?
  appointmentId String?
  channel       NotificationChannel @default(EMAIL)
  type          NotificationType
  status        NotificationStatus  @default(PENDING)
  sentAt        DateTime?
  errorMessage  String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  salon       Salon        @relation(fields: [salonId], references: [id], onDelete: Cascade)
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([salonId])
  @@index([clientId])
  @@index([appointmentId])
  @@map("notifications")
}

model NotificationPreference {
  id        String                      @id @default(cuid())
  scope     NotificationPreferenceScope
  scopeId   String // proUserId, clientId ou salonId selon scope
  type      NotificationType
  channel   NotificationChannel
  isEnabled Boolean                     @default(true)
  createdAt DateTime                    @default(now())
  updatedAt DateTime                    @updatedAt

  @@unique([scope, scopeId, type, channel])
  @@map("notification_preferences")
}

// ---------------------------------------------------------------------------
// INTÉGRATIONS & TRANSVERSE
// ---------------------------------------------------------------------------

model IntegrationConnection {
  id                   String              @id @default(cuid())
  organizationId       String
  salonId              String?
  provider             IntegrationProvider
  authType             IntegrationAuthType
  status               IntegrationStatus   @default(INACTIVE)
  // Les credentials ne sont JAMAIS stockés en clair.
  // Ils sont chiffrés avant insertion et déchiffrés à la lecture.
  encryptedCredentials String?
  expiresAt            DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salon        Salon?       @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("integration_connections")
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  actorId        String? // ProUser (null si action système)
  action         String
  entityType     String
  entityId       String
  metadata       Json?
  ipAddress      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        ProUser?     @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model FeatureFlag {
  id             String   @id @default(cuid())
  organizationId String
  flag           String
  isEnabled      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, flag])
  @@index([organizationId])
  @@map("feature_flags")
}

// ---------------------------------------------------------------------------
// CAISSE (POS) — Sprint 14
// ---------------------------------------------------------------------------

model Payment {
  id                 String        @id @default(cuid())
  organizationId     String
  salonId            String
  appointmentId      String?
  clientId           String?
  guestName          String?
  method             PaymentMethod
  status             PaymentStatus @default(COMPLETED)
  amountCents        Int
  paidAt             DateTime
  receiptNumber      String?
  notes              String?
  createdByProUserId String?
  isActive           Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  salon             Salon        @relation(fields: [salonId], references: [id], onDelete: Restrict)
  appointment       Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  client            Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdBy         ProUser?     @relation(fields: [createdByProUserId], references: [id], onDelete: SetNull)
  lines             PaymentLine[]
  commissionEntries CommissionEntry[]

  @@index([salonId, paidAt])
  @@index([appointmentId])
  @@index([clientId])
  @@index([organizationId, paidAt])
  @@index([createdByProUserId])
  @@map("payments")
}

model PaymentLine {
  id             String   @id @default(cuid())
  paymentId      String
  label          String
  unitPriceCents Int
  quantity       Int      @default(1)
  totalCents     Int      // toujours = unitPriceCents * quantity, calculé côté service
  serviceId      String?
  createdAt      DateTime @default(now())

  payment         Payment         @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  service         Service?        @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  commissionEntry CommissionEntry?

  @@index([paymentId])
  @@map("payment_lines")
}

// ---------------------------------------------------------------------------
// STOCKS & PRODUITS — Sprint 16
// ---------------------------------------------------------------------------

model ProductCategory {
  id             String   @id @default(cuid())
  salonId        String
  organizationId String
  name           String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  salon    Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([salonId, name])
  @@index([salonId])
  @@map("product_categories")
}

model Product {
  id                String   @id @default(cuid())
  salonId           String
  organizationId    String
  categoryId        String?
  name              String
  description       String?
  unit              String   @default("unité")
  priceCents        Int
  costPriceCents    Int?
  lowStockThreshold Int      @default(5)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  salon                     Salon            @relation(fields: [salonId], references: [id], onDelete: Restrict)
  category                  ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  stock                     ProductStock?
  movements                 StockMovement[]
  purchaseOrderLines        PurchaseOrderLine[]
  purchaseOrderReceiptLines PurchaseOrderReceiptLine[]
  commissionRules           CommissionRule[]

  @@index([salonId])
  @@index([organizationId])
  @@map("products")
}

model ProductStock {
  id        String   @id @default(cuid())
  salonId   String
  productId String   @unique
  quantity  Int      @default(0)
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  salon   Salon   @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([salonId])
  @@map("product_stocks")
}

model StockMovement {
  id                 String            @id @default(cuid())
  salonId            String
  organizationId     String
  productId          String
  type               StockMovementType
  quantityDelta      Int
  quantityBefore     Int
  quantityAfter      Int
  costPriceCents     Int?
  notes              String?
  referenceId        String?
  referenceType      String?
  createdByProUserId String?
  createdAt          DateTime          @default(now())

  product     Product                   @relation(fields: [productId], references: [id], onDelete: Restrict)
  salon       Salon                     @relation(fields: [salonId], references: [id], onDelete: Restrict)
  createdBy   ProUser?                  @relation(fields: [createdByProUserId], references: [id], onDelete: SetNull)
  receiptLine PurchaseOrderReceiptLine?

  @@index([salonId, createdAt])
  @@index([productId, createdAt])
  @@index([organizationId, createdAt])
  @@map("stock_movements")
}

// ---------------------------------------------------------------------------
// CAISSE POS — Compteur numérotation reçus (Sprint 15)
// ---------------------------------------------------------------------------

// Compteur de numérotation des reçus — 1 ligne par (salon, année)
// Incrémenté atomiquement dans la $transaction de création de paiement
model SalonReceiptCounter {
  id      String @id @default(cuid())
  salonId String
  year    Int
  lastSeq Int    @default(0)

  salon Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@unique([salonId, year])
  @@map("salon_receipt_counters")
}

// ---------------------------------------------------------------------------
// FOURNISSEURS & BONS DE COMMANDE — Sprint 17
// ---------------------------------------------------------------------------

model Supplier {
  id             String   @id @default(cuid())
  salonId        String
  organizationId String
  name           String
  contactName    String?
  email          String?
  phone          String?
  address        String?
  notes          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  salon          Salon           @relation(fields: [salonId], references: [id], onDelete: Restrict)
  purchaseOrders PurchaseOrder[]

  @@unique([salonId, name])
  @@index([salonId])
  @@index([organizationId])
  @@map("suppliers")
}

model PurchaseOrder {
  id                 String              @id @default(cuid())
  salonId            String
  organizationId     String
  supplierId         String
  status             PurchaseOrderStatus @default(DRAFT)
  reference          String?
  expectedAt         DateTime?
  notes              String?
  createdByProUserId String?
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  salon     Salon                  @relation(fields: [salonId], references: [id], onDelete: Restrict)
  supplier  Supplier               @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  createdBy ProUser?               @relation(fields: [createdByProUserId], references: [id], onDelete: SetNull)
  lines     PurchaseOrderLine[]
  receipts  PurchaseOrderReceipt[]

  @@index([salonId])
  @@index([organizationId])
  @@index([supplierId])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id              String   @id @default(cuid())
  salonId         String
  organizationId  String
  purchaseOrderId String
  productId       String
  quantityOrdered Int
  unitCostCents   Int
  notes           String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrder PurchaseOrder              @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product                    @relation(fields: [productId], references: [id], onDelete: Restrict)
  receiptLines  PurchaseOrderReceiptLine[]

  @@index([purchaseOrderId])
  @@index([productId])
  @@map("purchase_order_lines")
}

model PurchaseOrderReceipt {
  id                 String   @id @default(cuid())
  salonId            String
  organizationId     String
  purchaseOrderId    String
  receivedAt         DateTime @default(now())
  notes              String?
  createdByProUserId String?
  createdAt          DateTime @default(now())

  salon         Salon                    @relation(fields: [salonId], references: [id], onDelete: Restrict)
  purchaseOrder PurchaseOrder            @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict)
  createdBy     ProUser?                 @relation(fields: [createdByProUserId], references: [id], onDelete: SetNull)
  lines         PurchaseOrderReceiptLine[]

  @@index([salonId])
  @@index([purchaseOrderId])
  @@map("purchase_order_receipts")
}

model PurchaseOrderReceiptLine {
  id                  String   @id @default(cuid())
  receiptId           String
  purchaseOrderLineId String
  productId           String
  quantityReceived    Int
  unitCostCents       Int
  totalCostCents      Int
  stockMovementId     String   @unique
  createdAt           DateTime @default(now())

  receipt           PurchaseOrderReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  purchaseOrderLine PurchaseOrderLine    @relation(fields: [purchaseOrderLineId], references: [id], onDelete: Restrict)
  product           Product              @relation(fields: [productId], references: [id], onDelete: Restrict)
  stockMovement     StockMovement        @relation(fields: [stockMovementId], references: [id], onDelete: Restrict)

  @@index([receiptId])
  @@index([purchaseOrderLineId])
  @@map("purchase_order_receipt_lines")
}

// ---------------------------------------------------------------------------
// ABONNEMENTS SAAS — Sprint 18
// ---------------------------------------------------------------------------

// Catalogue des plans — 1 ligne par plan commercial (ESSENTIAL/PRO/BUSINESS)
model BillingPlan {
  id                String               @id @default(cuid())
  code              SubscriptionPlanCode @unique
  name              String
  description       String?
  monthlyPriceCents Int
  yearlyPriceCents  Int
  maxSalons         Int?  // null = illimité
  maxEmployees      Int?  // null = illimité
  isActive          Boolean              @default(true)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  subscriptions OrganizationSubscription[]

  @@map("billing_plans")
}

// Abonnement actif d'une organisation — 1 ligne par org
model OrganizationSubscription {
  id                 String                @id @default(cuid())
  organizationId     String                @unique
  planId             String
  billingCycle       BillingCycle          @default(MONTHLY)
  status             OrgSubscriptionStatus @default(TRIAL)
  isFree             Boolean               @default(false) @map("is_free")
  freeReason         String?               @map("free_reason")
  trialEndsAt        DateTime?
  currentPeriodStart DateTime              @default(now())
  currentPeriodEnd   DateTime
  canceledAt         DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         BillingPlan       @relation(fields: [planId], references: [id])
  discounts    BillingDiscount[]

  @@index([planId])
  @@map("organization_subscriptions")
}

// ---------------------------------------------------------------------------
// SUPER ADMIN SAAS — Sprint 19
// ---------------------------------------------------------------------------

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  isActive     Boolean  @default(true)  @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt       @map("updated_at")

  auditLogs         AdminAuditLog[]
  notes             OrganizationAdminNote[]
  impersonationLogs AdminImpersonationLog[]
  discountsCreated  BillingDiscount[]       @relation("DiscountCreatedBy")
  discountsDeactivated BillingDiscount[]    @relation("DiscountDeactivatedBy")

  @@map("admin_users")
}

model AdminAuditLog {
  id           String      @id @default(cuid())
  adminId      String      @map("admin_id")
  action       AdminAction
  targetOrgId  String?     @map("target_org_id")
  reason       String
  details      Json
  createdAt    DateTime    @default(now()) @map("created_at")

  admin     AdminUser    @relation(fields: [adminId], references: [id])
  targetOrg Organization? @relation(fields: [targetOrgId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([targetOrgId])
  @@map("admin_audit_logs")
}

model BillingDiscount {
  id                   String       @id @default(cuid())
  subscriptionId       String       @map("subscription_id")
  type                 DiscountType
  value                Int
  reason               String
  startDate            DateTime     @map("start_date")
  endDate              DateTime?    @map("end_date")
  isActive             Boolean      @default(true)         @map("is_active")
  createdByAdminId     String       @map("created_by_admin_id")
  createdAt            DateTime     @default(now())        @map("created_at")
  deactivatedAt        DateTime?    @map("deactivated_at")
  deactivatedByAdminId String?      @map("deactivated_by_admin_id")

  subscription        OrganizationSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  createdBy           AdminUser                @relation("DiscountCreatedBy", fields: [createdByAdminId], references: [id])
  deactivatedBy       AdminUser?               @relation("DiscountDeactivatedBy", fields: [deactivatedByAdminId], references: [id])

  @@index([subscriptionId])
  @@map("billing_discounts")
}

model AdminImpersonationLog {
  id             String    @id @default(cuid())
  adminId        String    @map("admin_id")
  organizationId String    @map("organization_id")
  startedAt      DateTime  @default(now()) @map("started_at")
  endedAt        DateTime? @map("ended_at")

  admin        AdminUser    @relation(fields: [adminId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([organizationId])
  @@map("admin_impersonation_logs")
}

model OrganizationAdminNote {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  adminId        String   @map("admin_id")
  content        String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt       @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  admin        AdminUser    @relation(fields: [adminId], references: [id])

  @@index([organizationId])
  @@map("organization_admin_notes")
}

// ---------------------------------------------------------------------------
// COMMISSIONS EMPLOYÉS — Sprint 20
// ---------------------------------------------------------------------------

model CommissionRule {
  id                 String         @id @default(cuid())
  organizationId     String
  salonId            String
  employeeId         String?        // null = s'applique à tous les employés
  serviceId          String?        // null = toutes les prestations
  productId          String?        // null = tous les produits (serviceId et productId ne peuvent pas être tous deux non-nuls)
  type               CommissionType
  value              Int            // 0–100 pour PERCENTAGE, centimes pour FIXED_AMOUNT
  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  createdByProUserId String

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salon        Salon           @relation(fields: [salonId], references: [id], onDelete: Cascade)
  employee     Employee?       @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  service      Service?        @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  product      Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdBy    ProUser         @relation(fields: [createdByProUserId], references: [id])
  entries      CommissionEntry[]

  @@index([organizationId, salonId, isActive])
  @@index([employeeId])
  @@map("commission_rules")
}

model CommissionEntry {
  id              String                @id @default(cuid())
  organizationId  String
  salonId         String
  employeeId      String
  paymentId       String
  paymentLineId   String?               @unique
  appointmentId   String?
  ruleId          String?
  type            CommissionType
  baseAmountCents Int
  commissionCents Int
  status          CommissionEntryStatus @default(PENDING)
  description     String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salon        Salon                  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  employee     Employee               @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payment      Payment                @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  paymentLine  PaymentLine?           @relation(fields: [paymentLineId], references: [id], onDelete: SetNull)
  appointment  Appointment?           @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  rule         CommissionRule?        @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  adjustments  CommissionAdjustment[]

  @@index([paymentId])
  @@index([employeeId, createdAt])
  @@index([organizationId, salonId, createdAt])
  @@map("commission_entries")
}

model CommissionAdjustment {
  id                  String   @id @default(cuid())
  entryId             String
  adjustedByProUserId String
  deltaCents          Int
  reason              String
  createdAt           DateTime @default(now())

  entry      CommissionEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  adjustedBy ProUser         @relation(fields: [adjustedByProUserId], references: [id])

  @@index([entryId])
  @@map("commission_adjustments")
}
